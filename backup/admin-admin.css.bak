/* ===== ADMIN PANEL STYLES ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --gold: #c9a84c;
  --gold-light: #e2c97e;
  --bg: #0d0d0d;
  --surface: #161616;
  --surface2: #1e1e1e;
  --border: rgba(255,255,255,0.08);
  --text: #f0ece4;
  --text-muted: #7a7570;
  --radius: 10px;
  --sidebar-w: 220px;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  cursor: url('/assets/podcast-watermark.jpg') 16 16, auto;
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
}

/* ===== LOGIN ===== */
.login-screen {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(ellipse at center, #1a1508 0%, #0d0d0d 70%);
}
.login-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 48px 40px;
  width: 100%;
  max-width: 380px;
  text-align: center;
  box-shadow: 0 24px 80px rgba(0,0,0,0.6);
}
.login-screen.hidden { display: none !important; }
.login-logo {
  width: 160px;
  height: 160px;
  object-fit: cover;
  margin-bottom: 20px;
  border-radius: 50%;
  border: 2px solid rgba(201,168,76,0.4);
  box-shadow: 0 0 30px rgba(201,168,76,0.2);
  display: block;
  margin-left: auto;
  margin-right: auto;
}
.login-title {
  font-family: 'DM Serif Display', serif;
  font-size: 28px;
  margin-bottom: 4px;
}
.login-sub {
  color: var(--gold);
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 32px;
}
.login-field {
  text-align: left;
  margin-bottom: 20px;
}
.login-field label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}
.login-field input {
  width: 100%;
  padding: 14px 16px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  outline: none;
  transition: border-color 0.2s;
}
.login-field input:focus { border-color: var(--gold); }
.pass-wrap {
  position: relative;
  display: flex;
  align-items: center;
}
.pass-wrap input {
  padding-right: 48px;
}
.pass-toggle {
  position: absolute;
  right: 14px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text-muted);
  padding: 0;
  display: flex;
  align-items: center;
  transition: color 0.2s;
}
.pass-toggle:hover { color: var(--gold); }
.login-error {
  color: #e07070;
  font-size: 13px;
  margin-top: 12px;
}

/* ===== BUTTONS ===== */
.btn-gold {
  width: 100%;
  padding: 14px 24px;
  background: var(--gold);
  border: none;
  border-radius: var(--radius);
  color: #0d0d0d;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.btn-gold:hover { background: var(--gold-light); transform: translateY(-1px); }
.btn-gold.btn-sm { width: auto; padding: 9px 18px; font-size: 12px; }

.btn-ghost {
  width: 100%;
  padding: 10px 18px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
  text-align: left;
}
.btn-ghost:hover { border-color: var(--gold); background: rgba(201,168,76,0.06); }
.btn-ghost.btn-sm { width: auto; }

.btn-outline {
  width: 100%;
  padding: 10px 18px;
  background: transparent;
  border: 1px solid rgba(255,80,80,0.3);
  border-radius: var(--radius);
  color: #e07070;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
  text-align: left;
}
.btn-outline:hover { border-color: #e07070; background: rgba(224,112,112,0.08); }

/* ===== DASHBOARD LAYOUT ===== */
.dashboard {
  display: flex;
  min-height: 100vh;
}

/* ===== SIDEBAR ===== */
.sidebar {
  width: var(--sidebar-w);
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0; bottom: 0;
  z-index: 100;
  overflow-y: auto;
}
.sidebar__brand {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 20px 18px;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--gold);
}
.sidebar__logo {
  width: 52px;
  height: 52px;
  object-fit: cover;
  border-radius: 50%;
  border: 1px solid rgba(201,168,76,0.3);
}
.sidebar__nav {
  flex: 1;
  padding: 16px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.nav-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  border-radius: 8px;
  border: none;
  background: transparent;
  color: var(--text-muted);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  text-align: left;
  transition: color 0.2s, background 0.2s;
  width: 100%;
}
.nav-item:hover { color: var(--text); background: rgba(255,255,255,0.04); }
.nav-item.active { color: var(--gold); background: rgba(201,168,76,0.1); }

.sidebar__actions {
  padding: 16px 12px;
  border-top: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ===== MAIN CONTENT ===== */
.main-content {
  margin-left: var(--sidebar-w);
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 32px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  position: sticky;
  top: 0;
  z-index: 50;
}
.topbar__left {
  display: flex;
  align-items: center;
  gap: 14px;
}
.topbar__logo {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  object-fit: cover;
  border: 1px solid rgba(201,168,76,0.3);
}
.topbar__title {
  font-family: 'DM Serif Display', serif;
  font-size: 22px;
  font-weight: 400;
}
.save-status {
  font-size: 12px;
  color: var(--gold);
  opacity: 0;
  transition: opacity 0.3s;
}
.save-status.visible { opacity: 1; }

/* ===== TAB PANELS ===== */
.tab-panel {
  display: none;
  padding: 32px;
}
.tab-panel.active { display: block; }

/* ===== CARDS ===== */
.panel-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 20px;
}
.panel-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
}
.card-title {
  font-family: 'DM Serif Display', serif;
  font-size: 16px;
  font-weight: 400;
  color: var(--gold);
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.card-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.card-header-row .card-title { margin: 0; padding: 0; border: none; }

/* ===== FORM ELEMENTS ===== */
.form-row {
  margin-bottom: 16px;
}
.form-row label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 6px;
}
.form-row input[type="text"],
.form-row input[type="url"],
.form-row input[type="password"],
.form-row input[type="number"],
.form-row textarea {
  width: 100%;
  padding: 10px 14px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
  resize: vertical;
}
.form-row input:focus,
.form-row textarea:focus { border-color: var(--gold); }

.hint {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}
.msg {
  font-size: 12px;
  margin-top: 8px;
  padding: 8px 12px;
  border-radius: 6px;
  background: rgba(201,168,76,0.1);
  color: var(--gold);
}
.msg.error { background: rgba(224,112,112,0.1); color: #e07070; }

.platforms-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 20px;
}

/* ===== EPISODES LIST ===== */
.episodes-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.ep-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  transition: border-color 0.2s;
}
.ep-row:hover { border-color: rgba(201,168,76,0.3); }
.ep-thumb {
  width: 52px;
  height: 36px;
  object-fit: cover;
  border-radius: 4px;
  flex-shrink: 0;
  background: #222;
}
.ep-info { flex: 1; min-width: 0; }
.ep-info strong {
  display: block;
  font-size: 13px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ep-info span {
  font-size: 11px;
  color: var(--text-muted);
}
.ep-actions { display: flex; gap: 6px; flex-shrink: 0; }
.ep-btn {
  padding: 5px 12px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text);
  font-size: 11px;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
}
.ep-btn:hover { border-color: var(--gold); color: var(--gold); }
.ep-btn.delete { border-color: rgba(224,112,112,0.3); color: #e07070; }
.ep-btn.delete:hover { border-color: #e07070; background: rgba(224,112,112,0.08); }

/* ===== TIERS LIST ===== */
.tiers-list { display: flex; flex-direction: column; gap: 10px; }
.tier-row {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 10px;
  align-items: center;
  padding: 12px 14px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
}
.tier-row label {
  font-size: 11px;
  color: var(--text-muted);
  display: block;
  margin-bottom: 4px;
  letter-spacing: 0.04em;
}
.tier-row input {
  width: 100%;
  padding: 8px 10px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  outline: none;
}
.tier-row input:focus { border-color: var(--gold); }

/* ===== EPISODE DRAWER (inline, no hidden-attribute issues) ===== */
.ep-drawer {
  margin-top: 16px;
  border: 1px solid var(--gold);
  border-radius: var(--radius);
  background: var(--surface2);
  overflow: hidden;
  animation: drawerOpen 0.25s ease;
}
@keyframes drawerOpen {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}
.ep-drawer__inner {
  padding: 28px;
}
.ep-drawer__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 20px;
}
.ep-drawer__grid .form-row:nth-child(3) {
  grid-column: 1 / -1;
}
.drawer-actions {
  display: flex;
  gap: 12px;
}
.drawer-actions .btn-gold  { flex: 1; width: auto; }
.drawer-actions .btn-ghost { flex: 1; width: auto; }

/* ===== FILE UPLOAD AREA ===== */
.upload-area {
  width: 100%;
  min-height: 120px;
  border: 2px dashed var(--border);
  border-radius: 8px;
  cursor: pointer;
  overflow: hidden;
  transition: border-color 0.2s;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.upload-area:hover { border-color: var(--gold); }
.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  color: var(--text-muted);
  font-size: 13px;
  padding: 20px;
}
.upload-icon { font-size: 28px; }
.ep-preview {
  width: 100%;
  height: 160px;
  object-fit: cover;
  display: block;
}

/* ===== TOAST ===== */
.toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  padding: 14px 22px;
  background: var(--gold);
  color: #0d0d0d;
  font-weight: 600;
  font-size: 13px;
  border-radius: 10px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  z-index: 9999;
  animation: slideUp 0.3s ease;
}
.toast.error { background: #e07070; color: #fff; }
@keyframes slideUp {
  from { transform: translateY(20px); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }

/* ===== DIALOGUE AI TAB ===== */
.dialogue-nav { border-top: 1px solid var(--border); margin-top: 8px; padding-top: 8px; color: var(--gold) !important; }

.dialogue-card { margin-bottom: 20px; }

.dlg-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
@media (max-width: 700px) { .dlg-grid { grid-template-columns: 1fr; } }

.req { color: var(--gold); }

.dlg-actions { margin-top: 20px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }

.dlg-spinner {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 16px;
  color: var(--text-muted);
  font-size: 14px;
}
.spinner-ring {
  width: 20px; height: 20px;
  border: 2px solid var(--border);
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }

.dlg-error {
  margin-top: 14px;
  padding: 12px 16px;
  background: rgba(224, 112, 112, 0.1);
  border: 1px solid rgba(224, 112, 112, 0.3);
  border-radius: 8px;
  color: #e07070;
  font-size: 13px;
  line-height: 1.5;
}

.dlg-output-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 16px;
}
.dlg-output-actions { display: flex; gap: 8px; flex-wrap: wrap; }

.dlg-script-wrap {
  position: relative;
  width: 100%;
  border: 1px solid var(--gold) !important;
  border-radius: 10px;
  overflow: hidden;
  background: #ffffff !important;
  transition: border-color 0.2s;
}
.dlg-watermark-overlay {
  position: absolute;
  inset: 0;
  background: url('/assets/podcast-watermark.jpg') center center / 340px 340px no-repeat;
  opacity: 0.08;
  pointer-events: none;
  z-index: 1;
}
.dlg-script-area {
  position: relative;
  z-index: 2;
  display: block;
  width: 100%;
  min-height: 420px;
  padding: 16px;
  background: #ffffff !important;
  border: none !important;
  border-radius: 0;
  color: #111111 !important;
  font-family: 'DM Sans', monospace;
  font-size: 13px;
  line-height: 1.7;
  resize: vertical;
  outline: none;
  box-shadow: none !important;
}

.dlg-modify-section {
  margin-top: 24px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
}
.dlg-modify-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-muted);
  margin-bottom: 12px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.dlg-modify-input {
  width: 100%;
  padding: 12px 14px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  resize: vertical;
  outline: none;
  transition: border-color 0.2s;
}
.dlg-modify-input:focus { border-color: var(--gold); }



/* ── IMAGE AI TAB ── */
#tab-imageai textarea, #tab-imageai select {
  width:100%; background:var(--card); border:1px solid var(--border);
  color:var(--text); border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit;
}
#tab-imageai textarea { min-height:80px; resize:vertical; }
.img-two-col { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
@media(max-width:600px){ .img-two-col{ grid-template-columns:1fr; } }
.img-zone-label { font-size:12px; font-weight:700; letter-spacing:1px; color:var(--gold); margin-bottom:8px; text-transform:uppercase; }
.img-upload-zone {
  border:2px dashed var(--border); border-radius:12px; padding:20px 12px;
  cursor:pointer; transition:border-color .2s; min-height:160px;
  display:flex; align-items:center; justify-content:center;
}
.img-upload-zone:hover { border-color:var(--gold); }
.img-upload-placeholder { text-align:center; color:var(--muted); pointer-events:none; }
.img-remove-btn {
  position:absolute; top:6px; right:6px; background:rgba(0,0,0,.7);
  color:#fff; border:none; border-radius:6px; padding:3px 8px; font-size:12px; cursor:pointer;
}
.img-remove-btn:hover { background:#c0392b; }
.img-settings-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:20px; }
@media(max-width:600px){ .img-settings-row{ grid-template-columns:1fr; } }
.img-gen-btn {
  width:100%; padding:14px; font-size:15px; letter-spacing:1.5px; font-weight:700;
  background:linear-gradient(135deg,var(--gold),#b8860b); color:#000;
  border:none; border-radius:30px; cursor:pointer; transition:opacity .2s,transform .1s;
}
.img-gen-btn:hover:not(:disabled){ opacity:.88; transform:translateY(-1px); }
.img-gen-btn:disabled{ opacity:.5; cursor:not-allowed; }
.img-status-bar { margin-top:14px; text-align:center; }
.img-progress-track { width:100%; height:4px; background:var(--border); border-radius:2px; overflow:hidden; margin-bottom:8px; }
.img-progress-fill { height:100%; width:0%; background:var(--gold); border-radius:2px; transition:width .4s ease; animation:img-pp 1.5s ease-in-out infinite alternate; }
@keyframes img-pp { from{opacity:.6} to{opacity:1} }
#img-status-text { font-size:13px; color:var(--muted); }
.img-dot-spinner { display:inline-block; width:12px; height:12px; border:2px solid rgba(0,0,0,.3); border-top-color:#000; border-radius:50%; animation:spin .7s linear infinite; vertical-align:middle; }
.img-error-box { margin-top:12px; padding:12px 16px; background:rgba(220,50,50,.12); border:1px solid rgba(220,50,50,.3); border-radius:8px; color:#e05555; font-size:14px; }
/* Image AI tab — visible input fields */
#tab-imageai input[type="text"],
#tab-imageai textarea,
#tab-imageai select {
  width:100%; padding:10px 14px;
  background:#2a2a2a;
  border:1.5px solid rgba(255,255,255,0.18);
  border-radius:8px;
  color:#f0ece4;
  font-size:14px;
  font-family:inherit;
  outline:none;
  transition:border-color .2s;
}
#tab-imageai input[type="text"]:focus,
#tab-imageai textarea:focus,
#tab-imageai select:focus { border-color:var(--gold); }
#tab-imageai input[type="text"]::placeholder,
#tab-imageai textarea::placeholder { color:rgba(240,236,228,0.35); }
/* ── PODCAST VIDEO TAB ── */
.pv-two-col { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px; }
@media(max-width:700px){ .pv-two-col{ grid-template-columns:1fr; } }
.pv-upload-zone {
  border:2px dashed rgba(255,255,255,0.15);
  border-radius:10px;
  padding:20px 12px;
  text-align:center;
  cursor:pointer;
  transition:border-color .2s, background .2s;
  background:rgba(255,255,255,0.02);
  min-height:100px;
}
.pv-upload-zone:hover { border-color:var(--gold); background:rgba(201,168,76,0.05); }
.pv-audio-zone { min-height:80px; padding:14px 12px; }
.pv-upload-placeholder { pointer-events:none; }
#tab-podcastvideo input[type="text"] {
  width:100%; padding:10px 14px;
  background:#2a2a2a;
  border:1.5px solid rgba(255,255,255,0.18);
  border-radius:8px;
  color:#f0ece4;
  font-size:14px;
  font-family:inherit;
  outline:none;
  transition:border-color .2s;
}
#tab-podcastvideo input[type="text"]:focus { border-color:var(--gold); }
#tab-podcastvideo input[type="text"]::placeholder { color:rgba(240,236,228,0.35); }

.img-result-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px; margin-top:12px; }
.img-card { border-radius:12px; overflow:hidden; border:1px solid var(--border); background:var(--card); }
.img-card img { width:100%; display:block; }
.img-card-footer { padding:10px 12px; display:flex; gap:8px; }
.img-dl-btn { flex:1; padding:8px; border-radius:6px; border:1px solid var(--gold); background:transparent; color:var(--gold); font-size:12px; letter-spacing:.5px; cursor:pointer; transition:background .2s; }
.img-dl-btn:hover { background:var(--gold); color:#000; }
